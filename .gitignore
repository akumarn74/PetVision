# --------------------------
# PetVision Root GitIgnore
# --------------------------

# Environment Security (CRITICAL)
backend/.env
**/.env
**/.env.local
**/.env.*

# Python Ecosystem
**/venv/
**/env/
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/*.egg-info/
**/.ruff_cache/

# Docker Local Database Volumes
postgres_data/
*/postgres_data/

# OS / IDE Hidden Files
.DS_Store
.vscode/
.idea/
*.swp

# Flutter Mobile App (Root delegates to mobile_app/.gitignore)
mobile_app/build/
mobile_app/.dart_tool/
mobile_app/.flutter-plugins
mobile_app/.flutter-plugins-dependencies
